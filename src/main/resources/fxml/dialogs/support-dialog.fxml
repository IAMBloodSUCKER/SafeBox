<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.safebox.util.SupportDialogController"
      styleClass="dialog-root"
      spacing="0"
      prefWidth="460">
    <HBox styleClass="dialog-header" alignment="CENTER_LEFT" spacing="12">
        <padding>
            <Insets top="18" right="20" bottom="18" left="20"/>
        </padding>
        <Label fx:id="iconLabel" styleClass="dialog-icon"/>
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label fx:id="titleLabel" styleClass="dialog-title" wrapText="true"/>
            <Label fx:id="headerLabel" styleClass="dialog-header-text" wrapText="true"/>
        </VBox>
    </HBox>

    <VBox spacing="14" styleClass="dialog-body">
        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>
        <Label fx:id="introLabel" styleClass="dialog-message" wrapText="true"/>
        <VBox spacing="6">
            <Label fx:id="addressLabel" styleClass="field-label"/>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <TextField fx:id="addressField" styleClass="dialog-copy-field" editable="false"
                           HBox.hgrow="ALWAYS"/>
                <Button fx:id="copyAddressButton" onAction="#onCopyAddress" styleClass="dialog-button-secondary"/>
            </HBox>
        </VBox>
        <TextArea fx:id="detailsArea" styleClass="dialog-details-area" editable="false" wrapText="true"
                  prefRowCount="7"/>
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button fx:id="copyAllButton" onAction="#onCopyAll" styleClass="dialog-button-secondary"/>
            <Button fx:id="okButton" onAction="#onOk" defaultButton="true" styleClass="dialog-button-primary"/>
        </HBox>
    </VBox>
</VBox>
