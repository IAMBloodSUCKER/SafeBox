#!/bin/sh
# Блокирует коммит, если в сообщении осталась атрибуция Cursor.
COMMIT_MSG_FILE=$1
[ -f "$COMMIT_MSG_FILE" ] || exit 0

if grep -qiE 'cursoragent@cursor\.com|co-authored-by:.*cursor|made-with:.*cursor' "$COMMIT_MSG_FILE"; then
    echo "Коммит отклонён: в сообщении есть атрибуция Cursor." >&2
    echo "Уберите Co-authored-by / Made-with или отключите Attribution в Cursor Settings → Agents." >&2
    exit 1
fi

exit 0
