#!/bin/sh
# Удаляет атрибуцию Cursor из сообщений коммитов (страховка, если IDE всё же добавит trailer).
COMMIT_MSG_FILE=$1
[ -f "$COMMIT_MSG_FILE" ] || exit 0

grep -viE 'cursoragent@cursor\.com|^co-authored-by:.*cursor|^made-with:.*cursor' "$COMMIT_MSG_FILE" > "$COMMIT_MSG_FILE.tmp" \
  && mv "$COMMIT_MSG_FILE.tmp" "$COMMIT_MSG_FILE"

exit 0
